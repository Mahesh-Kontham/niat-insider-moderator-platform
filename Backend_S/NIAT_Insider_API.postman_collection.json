{
  "info": {
    "_postman_id": "niat-insider-api",
    "name": "NIAT Insider Moderator Platform API",
    "description": "Complete API collection for NIAT Insider Moderator Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/auth/login/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "auth", "login", ""]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/auth/me/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "auth", "me", ""]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"Admin@123456\",\n  \"new_password\": \"NewPassword@123456\",\n  \"confirm_password\": \"NewPassword@123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/auth/change-password/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "auth", "change-password", ""]
            }
          }
        },
        {
          "name": "Onboard New Moderator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"signed-token-from-email\",\n  \"password\": \"NewModerator@123\",\n  \"confirm_password\": \"NewModerator@123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/auth/onboard/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "auth", "onboard", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Operations",
      "item": [
        {
          "name": "Send Moderator Invite",
          "request": {
            "method": "POST",
