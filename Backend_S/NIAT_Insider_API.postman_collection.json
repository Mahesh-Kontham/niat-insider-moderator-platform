                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"moderator@test.com\",\n  \"campus_id\": \"campus-uuid\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/admin/invite/",
              "protocol": "http",
