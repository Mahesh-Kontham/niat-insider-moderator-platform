    {
      "name": "Articles",
      "item": [
        {
          "name": "List Articles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/articles/?category=NEWS&status=PUBLISHED&search=announcement&ordering=-created_at&page=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "articles", ""],
              "query": [
                {
                  "key": "category",
                  "value": "NEWS"
                },
                {
                  "key": "status",
                  "value": "PUBLISHED"
                },
                {
                  "key": "search",
                  "value": "announcement"
                },
                {
                  "key": "ordering",
                  "value": "-created_at"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Create Article",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Campus Event Announcement",
                  "type": "text"
                },
                {
                  "key": "body",
                  "value": "This is a detailed article about the campus event...",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "EVENT",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "PUBLISHED",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/api/articles/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "articles", ""]
            }
          }
        },
        {
          "name": "Get Article",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/articles/article-uuid/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "articles", "article-uuid", ""]
            }
          }
        },
        {
          "name": "Update Article",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Updated Article Title",
                  "type": "text"
                },
                {
                  "key": "body",
                  "value": "Updated article content...",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "DRAFT",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/api/articles/article-uuid/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "articles", "article-uuid", ""]
            }
          }
        },
        {
          "name": "Delete Article",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/articles/article-uuid/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "articles", "article-uuid", ""]
            }
          }
        },
        {
          "name": "Get Published Articles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/articles/published/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "articles", "published", ""]
