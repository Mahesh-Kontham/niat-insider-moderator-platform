          "name": "Revoke Invite",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_access_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/admin/revoke-invite/invite-uuid/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "admin", "revoke-invite", "invite-uuid", ""]
            }
          }
